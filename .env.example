APP_PORT=8080
SPRING_PROFILES_ACTIVE=local
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport

# Used by Docker Compose. For IDE/local Gradle runs, use OS env vars or config/application-secret.yaml.
# Required only when OpenAI chat model is enabled.
OPENAI_API_KEY=

# Required for Kakao OAuth login.
KAKAO_REST_API_KEY=
# Optional alias for Render or other hosts. Use this if you prefer this name over KAKAO_REST_API_KEY.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/api/v1/auth/kakao/callback

# Required in production. For local development, application-local.yaml uses H2 by default.
SPRING_DATASOURCE_URL=jdbc:postgresql://<host>:5432/<database>?sslmode=require
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_SSLMODE=require
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=3
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=0
SPRING_DATASOURCE_HIKARI_INITIALIZATION_FAIL_TIMEOUT=-1
SPRING_JPA_HIBERNATE_DDL_AUTO=none
